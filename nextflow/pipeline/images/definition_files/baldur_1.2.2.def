Bootstrap: docker
From: ubuntu:22.04

%labels
    Author czaka
    Version baldur-1.2.2

%post
    # Install system dependencies
    apt-get update && apt-get install -y \
        samtools \
        tabix \
        curl \
        git \
        wget \
        build-essential \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libssl-dev \
        libcurl4-openssl-dev \
        pkg-config \
        make \
        && apt-get clean

    # Install Rust
    curl https://sh.rustup.rs -sSf | bash -s -- -y
    export PATH=/root/.cargo/bin:$PATH

    # Clone and build HTSlib
    cd /opt
    wget https://github.com/samtools/htslib/releases/download/1.14/htslib-1.14.tar.bz2
    tar -xjf htslib-1.14.tar.bz2
    cd htslib-1.14
    ./configure --prefix=/opt/htslib
    make
    make install

    # Clone and build Baldur
    cd /opt
    git clone https://github.com/heathsc/baldur.git
    cd baldur
    # Compile using HTSlib from /opt/htslib
    RUSTFLAGS="-L /opt/htslib/lib" cargo build --release

    # Copy binary and data file for easy access
    mkdir -p /baldur-bin
    cp target/release/baldur /baldur-bin/
    cp share/blacklist.txt /baldur-bin/

%environment
    export PATH=/root/.cargo/bin:/baldur-bin:$PATH
    export LD_LIBRARY_PATH=/opt/htslib/lib:$LD_LIBRARY_PATH

