singularity {
  enabled = true
  autoMounts = true
  libraryDir = "${projectDir}/images"
  cacheDir = "${projectDir}/images"
  workDir = "${projectDir}/work"
}

params {

  // optional processes
  numt_profiling = false
  check_nuclear_coverage = false

  // ---- configurable parameters ----
  // numt filtration 
  max_sc_threshold = 200
  max_meth_threshold_per_read = 0.5
  meth_likelihood_threshold = 0.5 

  // baldur parameters
  indel_threshold = 0.1
  snv_soft_threshold = 0.0025
  snv_hard_threshold = 0.0005
  homopolymer_limit = 5
  deletion_size_limit = 25
  mapq_threshold = 20
  base_qual_threshold = 20 
  max_indel_base_qual = 30

  // sniffles parameters
  min_sv_support = 4

  // assembly paramters
  flye_min_overlap = 2500
  flye_iterations = 10
  flye_bp_tolerance = 100
  num_downsampled_reads = 100

  // singularity images
  python = 'oras://quay.io/czakarian/mitoscope:python_3.11'
  samtools = 'oras://quay.io/czakarian/mitoscope:samtools_1.21'
  bcftools = 'oras://quay.io/czakarian/mitoscope:bcftools_1.21'
  kmctools = 'oras://quay.io/czakarian/mitoscope:kmc_3.2.1'
  minimap = 'oras://quay.io/czakarian/mitoscope:minimap2_2.24_with_samtools_1.21'
  pigz = 'oras://quay.io/czakarian/mitoscope:pigz_2.8'
  minimod = 'oras://quay.io/czakarian/mitoscope:minimod_0.4.0_6805b5b'
  mosdepth = 'oras://quay.io/czakarian/mitoscope:mosdepth_0.3.8'
  mutserve = 'oras://quay.io/czakarian/mitoscope:mutserve_2.0.3'
  sniffles = 'oras://quay.io/czakarian/mitoscope:sniffles_2.6.2'
  bedtools = 'oras://quay.io/czakarian/mitoscope:bedtools_2.31.0'
  haplogrep = 'oras://quay.io/czakarian/mitoscope:haplogrep_3.2.2'
  haplocheck = 'oras://quay.io/czakarian/mitoscope:haplocheck_1.3.3'
  flye = 'oras://quay.io/czakarian/mitoscope:flye_2.9.6_with_seqtk_1.5'
  baldur = 'oras://quay.io/czakarian/mitoscope:baldur_1.3.0'
  blast = 'oras://quay.io/czakarian/mitoscope:blast_2.16.0'
  modkit = "oras://quay.io/czakarian/mitoscope:ont-modkit_0.5.0_hcdda2d0_2"
  pbcpgtools = "oras://quay.io/czakarian/mitoscope:pb-cpg-tools_3.0.0_h9ee0642_0"
  vep = "oras://quay.io/czakarian/mitoscope:ensembl-vep_115"

  // resources 
  kmc_pre = "${projectDir}/resources/MT.k29.kmc_pre"
  kmc_suf = "${projectDir}/resources/MT.k29.kmc_suf"
  mt_ref = "${projectDir}/resources/MT.fasta"
  mt_mmi_hifi = "${projectDir}/resources/MT-hifi.mmi"
  mt_mmi_ont = "${projectDir}/resources/MT-ont.mmi"
  mitomap_anno_file = "${projectDir}/resources/annotations/CombinedDiseaseVariantDB.csv"
  blast_db = "${projectDir}/resources/blast"
  vep_cache_dir = "${projectDir}/resources/vep/"
  circos_bed = "${projectDir}/resources/circos.bed"

  // misc params
  mplconfigdir = '/tmp/mplconfig'
  haplogrep_tree = 'phylotree-rcrs@17.2'

}

executor {
  queueSize = "20"
  cpus = 32
  memory = '400GB'
}

process {
  executor = 'local'  
  scratch = true

  cpus = 4
  memory = '8 GB'

  withName: ALIGNED_CRAM_TO_FASTQ {
    cpus = 8
    memory = '16 GB'
  }

  withName: ALIGNED_BAM_TO_FASTQ {
    cpus = 8
    memory = '16 GB'
  }

  withName: UNALIGNED_BAM_TO_FASTQ {
    cpus = 8
    memory = '16 GB'
  }

  withName: UNALIGNED_CRAM_TO_FASTQ {
    cpus = 8
    memory = '16 GB'
  }

  withName: COMPRESS_FASTQ {
    cpus = 8
    memory = '16 GB'
  }

  withName: KMER_SELECTION {
    cpus = 8
    memory = '16 GB'
  }

  withName: FILTER_NUMTS {
    cpus = 2
    memory = '8 GB'
  }

  withName: NUMT_DETECTION_SNIFFLES {
    cpus = 8
    memory = '32 GB'
  }

  withName: NUCLEAR_COVERAGE {
    cpus = 4
    memory = '16 GB'
  }


}