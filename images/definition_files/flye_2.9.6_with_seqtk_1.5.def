Bootstrap: docker
From: ubuntu:22.04

%labels
    Author Christina
    Version 1.0

%environment
    export PATH=/opt/bin:$PATH

%post
    #!/bin/bash
    set -eu pipefail
    
    echo "===== Installing base dependencies ====="
    apt-get update && apt-get install -y \
        build-essential \
        curl \
        wget \
        git \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libncurses5-dev \
        libncursesw5-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        autoconf \
        automake \
        cmake \
        make \
        unzip \
        default-jre \
        openjdk-17-jdk 

    mkdir -p /opt/bin

    echo "===== Installing Flye ====="
    FLYE_VERSION=2.9.6
    cd /opt && \
    git clone https://github.com/mikolmogorov/Flye && \
    cd Flye && \
    git checkout ${FLYE_VERSION} && \
    make && \
    ln -s /opt/Flye/bin/flye /opt/bin/flye

    echo "===== Installing seqtk ====="
    SEQTK_VERSION=1.5
    cd /opt && \
    git clone https://github.com/lh3/seqtk && \
    cd seqtk && \
    git checkout v${SEQTK_VERSION} && \
    make && \
    ln -s /opt/seqtk/seqtk /opt/bin/seqtk

    #########

    echo "===== Cleaning up ====="
    apt-get clean && rm -rf /var/lib/apt/lists/*
