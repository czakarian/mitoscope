Bootstrap: docker
From: ubuntu:22.04

%labels
    Author czaka
    Version baldur-1.3.0

%post
    # Install system dependencies
    apt-get update && apt-get install -y \
        samtools \
        tabix \
        curl \
        git \
        wget \
        build-essential \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libssl-dev \
        libcurl4-openssl-dev \
        pkg-config \
        make \
        && apt-get clean

    echo "===== Installing rust ====="
    curl https://sh.rustup.rs -sSf | bash -s -- -y
    export PATH=/root/.cargo/bin:$PATH

    echo "===== Installing htslib ====="
    HTSLIB_VERSION="1.14"
    cd /opt && \
    wget https://github.com/samtools/htslib/releases/download/${HTSLIB_VERSION}/htslib-${HTSLIB_VERSION}.tar.bz2 && \
    tar -xjf htslib-${HTSLIB_VERSION}.tar.bz2 && \
    cd htslib-${HTSLIB_VERSION} && \
    ./configure --prefix=/opt/htslib && \
    make && \
    make install

    echo "===== Installing baldur ====="
    BALDUR_VERSION="1.3.0" 
    BALDUR_HASH="73cb26e"
    cd /opt && \
    git clone https://github.com/heathsc/baldur.git && \
    cd baldur && \
    git checkout ${BALDUR_HASH} && \
    RUSTFLAGS="-L /opt/htslib/lib" cargo build --release

    # Copy binary and data file for easy access
    mkdir -p /baldur-bin
    cp target/release/baldur /baldur-bin/
    cp share/blacklist.txt /baldur-bin/

%environment
    export PATH=/root/.cargo/bin:/baldur-bin:$PATH
    export LD_LIBRARY_PATH=/opt/htslib/lib:$LD_LIBRARY_PATH

