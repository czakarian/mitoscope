Bootstrap: docker
From: ubuntu:22.04

%labels
    Author Christina
    Version 1.0

%environment
    export PATH=/opt/bin:$PATH

%post
    #!/bin/bash
    set -eu pipefail
    
    echo "===== Installing base dependencies ====="
    apt-get update && apt-get install -y \
        build-essential \
        curl \
        wget \
        git \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libncurses5-dev \
        libncursesw5-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        autoconf \
        automake \
        cmake \
        make \
        unzip \
        default-jre \
        openjdk-17-jdk 

    mkdir -p /opt/bin

    echo "===== Installing Minimap2 ====="
    MINIMAP_VERSION=2.24
    cd /opt && \
    git clone https://github.com/lh3/minimap2.git && \
    cd minimap2 && \
    git checkout v${MINIMAP_VERSION} && \
    make && \
    ln -s /opt/minimap2/minimap2 /opt/bin/minimap2

    echo "===== Installing samtools ====="
    SAMTOOLS_VERSION=1.21
    cd /opt && \
    wget https://github.com/samtools/samtools/releases/download/${SAMTOOLS_VERSION}/samtools-${SAMTOOLS_VERSION}.tar.bz2 && \
    tar -xjf samtools-${SAMTOOLS_VERSION}.tar.bz2 && \
    rm samtools-${SAMTOOLS_VERSION}.tar.bz2 && \
    cd samtools-${SAMTOOLS_VERSION} && \
    ./configure --prefix=/opt/samtools-${SAMTOOLS_VERSION} && make && make install && \
    ln -s /opt/samtools-${SAMTOOLS_VERSION}/bin/samtools /opt/bin/samtools

    #########

    echo "===== Cleaning up ====="
    apt-get clean && rm -rf /var/lib/apt/lists/*
